      {
        "type": "org.thingsboard.rule.engine.transform.TbTransformMsgNode",
        "name": "checkWaterLevel",
        "debugSettings": {
          "failuresEnabled": false,
          "allEnabled": false,
          "allEnabledUntil": 1772956282124
        },
        "singletonMode": false,
        "queueName": null,
        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "TBEL",
          "jsScript": "return {msg: msg, metadata: metadata, msgType: msgType};",
          "tbelScript": "// อ่านค่าจาก telemetry / attribute\r\nvar level = Math.round(msg.distanceOffset);\r\nvar autoOn = msg.shared_settingWaterAutoOn;\r\nvar autoOff = msg.shared_settingWaterAutoOff;\r\nvar pumpState = msg.shared_statePump;\r\n\r\n// กำหนดสถานะใหม่เริ่มต้น = สถานะเดิม\r\nvar newState = pumpState;\r\n\r\n// เงื่อนไขเปิดปั๊ม\r\nif (pumpState === false && level <= autoOn) {\r\n    newState = true;\r\n}\r\n\r\n// เงื่อนไขปิดปั๊ม\r\nif (pumpState === true && level >= autoOff) {\r\n    newState = false;\r\n}\r\n\r\n// ถ้าสถานะไม่เปลี่ยน\r\nif (newState == pumpState) {\r\n    msg.noChange = true;\r\n} else {\r\n    msg.statePump = newState;\r\n    msg.noChange = false;\r\n}\r\n\r\nreturn { msg: msg, metadata: metadata, msgType: msgType };"
        },
        "additionalInfo": {
          "description": "",
          "layoutX": 507,
          "layoutY": 523
        }
      },
      {
        "type": "org.thingsboard.rule.engine.transform.TbTransformMsgNode",
        "name": "AutoMode",
        "debugSettings": {
          "failuresEnabled": false,
          "allEnabled": false,
          "allEnabledUntil": 1772956282124
        },
        "singletonMode": false,
        "queueName": null,
        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "TBEL",
          "jsScript": "return {msg: msg, metadata: metadata, msgType: msgType};",
          "tbelScript": "var payload;\r\n\r\n// ตรวจสอบสถานะปั๊ม\r\nif (msg.statePump === true) {\r\n    payload = \"AAE=\";   // เปิดปั๊ม\r\n} else {\r\n    payload = \"AAA=\";   // ปิดปั๊ม\r\n}\r\n\r\nvar downlink = {\r\n    downlinks: [\r\n        {\r\n            f_port: 2,\r\n            frm_payload: payload,\r\n            priority: \"NORMAL\",\r\n            confirmed: true\r\n        }\r\n    ]\r\n};\r\n\r\nreturn {\r\n    msg: downlink,\r\n    metadata: metadata,\r\n    msgType: msgType\r\n};"
        },
        "additionalInfo": {
          "description": "",
          "layoutX": 978,
          "layoutY": 522
        }
