        "queueName": null,
        "configurationVersion": 0,
        "configuration": {
          "scriptLang": "TBEL",
          "jsScript": "return {msg: msg, metadata: metadata, msgType: msgType};",
          "tbelScript": "var payload = msg.downlinks != null ? msg.downlinks[0].frm_payload : null;\r\n\r\n// กำหนดสถานะปั๊มตาม payload\r\nif (payload == \"AAE=\") {\r\n    msg.statePump = true;\r\n} else if (payload == \"AAA=\") {\r\n    msg.statePump = false;\r\n}\r\n\r\n// ส่งไป update attribute\r\nreturn {\r\n    msg: msg,\r\n    metadata: metadata,\r\n    msgType: \"POST_ATTRIBUTES_REQUEST\"\r\n};"
        },
