          "jsScript": "return {msg: msg, metadata: metadata, msgType: msgType};",
          "tbelScript": "var mode = msg.shared_mode;\r\nvar sw = msg.shared_statePump;\r\n\r\n// สร้างเวลาสั้น ๆ\r\nvar now = new Date();\r\nmsg.time = now.getHours() + \":\" + now.getMinutes() + \":\" + now.getSeconds();\r\n\r\nif (mode == \"MANUAL\" && sw == true) {\r\n    msg.pump_status = \"Manual ON\";\r\n}\r\nelse if (mode == \"MANUAL\" && sw == false) {\r\n    msg.pump_status = \"Manual OFF\";\r\n}\r\nelse if (mode == \"AUTO\" && sw == true) {\r\n    msg.pump_status = \"Auto ON\";\r\n}\r\nelse if (mode == \"AUTO\" && sw == false) {\r\n    msg.pump_status = \"Auto OFF\";\r\n}\r\n\r\nreturn {msg: msg, metadata: metadata, msgType: msgType};"
        },
