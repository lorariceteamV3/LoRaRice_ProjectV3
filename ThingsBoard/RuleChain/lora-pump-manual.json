          "scriptLang": "TBEL",
          "jsScript": "return {msg: msg, metadata: metadata, msgType: msgType};",
          "tbelScript": "// mode มาจาก Shared attribute ที่ widget เพิ่ง save (AUTO / MANUAL)\r\nvar mode = msg.shared_mode;\r\nvar sw = msg.shared_statePump;\r\n\r\n// map เป็น frm_payload ที่ต้องการ\r\nvar payload = null;\r\nif (mode == \"AUTO\") {\r\n  payload = \"AAA=\";\r\n} else if (mode == \"MANUAL\") {\r\n    if(sw == true){\r\n        payload = \"AQE=\";\r\n    }\r\n    else if (sw == false){\r\n        payload = \"AQA=\";\r\n    }\r\n    else{\r\n        return null;\r\n    }\r\n}\r\nelse {\r\n  return null; // ไม่ใช่โหมดที่รองรับก็ไม่ส่ง\r\n}\r\n\r\n// สร้าง output ให้ตรงรูปแบบที่ต้องการ\r\nreturn {\r\n  msg: {\r\n    downlinks: [\r\n      {\r\n        f_port: \"2\",\r\n        frm_payload: payload,\r\n        priority: \"NORMAL\",\r\n        confirmed: true\r\n      }\r\n    ]\r\n  },\r\n  metadata: {\r\n    deviceType: metadata.deviceType,\r\n    deviceName: metadata.deviceName,\r\n    ts: metadata.ts\r\n  },\r\n  msgType: \"POST_TELEMETRY_REQUEST\"\r\n};\r\n"
        },
